# ============================================================
# RideFleet Core — .gitignore
# ============================================================

# ------------------------------------------------------------
# Environment & secrets
# ------------------------------------------------------------
.env
.env.*
!.env.example

# ------------------------------------------------------------
# Python
# ------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/
*.so

# Virtual environments
.venv/
venv/
env/
ENV/
.virtualenv/

# pytest / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover

# mypy / ruff / pyright caches
.mypy_cache/
.ruff_cache/
.pyright/
pyrightconfig.json

# ------------------------------------------------------------
# Node.js (contract tests)
# ------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock
.pnpm-lock.yaml

# Test reports (generated by CI — not source files)
conformance/tests/contract/reports/

# ------------------------------------------------------------
# Docker
# ------------------------------------------------------------
# Keep all compose files and Dockerfiles tracked.
# Ignore only generated/runtime artifacts.
*.tar
docker-compose.override.yml

# ------------------------------------------------------------
# Editors & IDEs
# ------------------------------------------------------------
.vscode/
.idea/
*.iml
*.iws
*.ipr
*.sublime-project
*.sublime-workspace
.editorconfig.local

# ------------------------------------------------------------
# OS artifacts
# ------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db

# ------------------------------------------------------------
# Logs & temp files
# ------------------------------------------------------------
*.log
*.tmp
*.temp
*.swp
*.swo
*~

# ------------------------------------------------------------
# Grafana & Prometheus runtime data
# Keep dashboard JSONs and provisioning YAMLs tracked.
# Ignore only runtime volumes mounted outside the repo.
# ------------------------------------------------------------
# (nothing to ignore here — all config is in observability/ and tracked)
