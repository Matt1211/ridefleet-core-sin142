# ============================================================
# RideFleet Core — variáveis de ambiente
# Copie para .env e preencha os valores antes de subir o stack.
# NUNCA commite o arquivo .env no Git.
# ============================================================

# Ambiente de execução
CORE_ENV=development

# Redis (broker/lock store provisional — pendente ADR-002)
REDIS_URL=redis://redis:6379

# Grafana
GRAFANA_ADMIN_PASSWORD=ridefleet

# Imagens dos serviços dos grupos (usadas em docker-compose.yml)
# GROUP_A_IMAGE=ghcr.io/grupo-a/ridefleet-service:latest
# GROUP_B_IMAGE=ghcr.io/grupo-b/ridefleet-service:latest
# GROUP_C_IMAGE=ghcr.io/grupo-c/ridefleet-service:latest
# GROUP_D_IMAGE=ghcr.io/grupo-d/ridefleet-service:latest
# GROUP_E_IMAGE=ghcr.io/grupo-e/ridefleet-service:latest
